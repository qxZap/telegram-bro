# Convex deploy key (Settings > Deploy Keys in dashboard.convex.dev).
# Format: dev:<deployment-name>|<token> or prod:<deployment-name>|<token>.
# Used by `npx convex` CLI commands invoked from setup.ts.
CONVEX_DEPLOY_KEY=

# Optional override for the agent identifier used by telegram-send /
# telegram-wait. Defaults to a slug derived from the cwd path
# (e.g. D:\Repos\my-bot -> d-repos-my-bot).
# TELEGRAM_AGENT_ID=

# Optional Telegram webhook secret. If set here AND in Convex env
# (`npx convex env set TELEGRAM_WEBHOOK_SECRET ...`) AND on the webhook
# registration (setWebhook with secret_token), the HTTP action enforces
# it. Recommended for shared/public deployments; not required for
# personal use since the webhook URL is unguessable.
# TELEGRAM_WEBHOOK_SECRET=
